# Operately Production Environment Configuration
# Copy this file to operately.env on your VPS and fill in the values.
# Source: https://github.com/hungcuong9125/operately

# --- Domain ---
OPERATELY_HOST="your-domain.com"

# --- Blob Storage ---
OPERATELY_BLOB_TOKEN_SECRET_KEY="<run: openssl rand -base64 32>"
OPERATELY_INSTALLATION_ID="<run: openssl rand -hex 16>"

# --- SSL (Let's Encrypt) ---
CERT_DOMAIN="your-domain.com"
CERT_AUTO_RENEW="yes"
CERT_EMAILS="admin@your-domain.com"
OPERATELY_URL_SCHEME="https"

# --- App Secrets ---
SECRET_KEY_BASE="<run: openssl rand -hex 32>"
SYSTEM_SETTINGS_ENCRYPTION_KEYS="<run: openssl rand -hex 32>"

# --- PostgreSQL ---
DB_USERNAME="operately"
POSTGRES_USER="operately"
POSTGRES_PASSWORD="<run: openssl rand -hex 32>"
DATABASE_URL="ecto://operately:<password>@db/operately"

# --- Feature Flags ---
ALLOW_LOGIN_WITH_EMAIL="yes"
ALLOW_SIGNUP_WITH_EMAIL="yes"
OPERATELY_BEACON_ENABLED="true"

# --- Email Delivery (optional) ---
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USERNAME="your-email@example.com"
# SMTP_PASSWORD="your-password"
# SMTP_PROVIDER=""              # Set to "aws-ses" for AWS SES, leave empty for generic SMTP
