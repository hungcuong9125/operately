# Operately Production Environment Configuration
# Copy to operately.env and fill values. Dokploy: set these in Environment Variables UI instead.
# SSL handled by Dokploy (Caddy reverse proxy). App runs on internal port 4000.

OPERATELY_HOST="your-domain.com"
OPERATELY_URL_SCHEME="https"
CERT_DOMAIN="your-domain.com"
CERT_EMAILS="admin@your-domain.com"

# Secrets (generate with: openssl rand -base64 32 / openssl rand -hex 32)
OPERATELY_BLOB_TOKEN_SECRET_KEY=""
OPERATELY_INSTALLATION_ID=""
SECRET_KEY_BASE=""
SYSTEM_SETTINGS_ENCRYPTION_KEYS=""

# Database
DATABASE_URL="ecto://operately:<password>@db/operately"
POSTGRES_PASSWORD=""

# Features
ALLOW_LOGIN_WITH_EMAIL="yes"
ALLOW_SIGNUP_WITH_EMAIL="yes"
OPERATELY_BEACON_ENABLED="true"
